# Payment Gateway MVP - Environment Configuration

# Frontend API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8081/api

# Backend Configuration
NEXT_PUBLIC_APP_NAME=PaymentGateway
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Authentication
JWT_SECRET=your-secret-key-here-min-32-characters-long
JWT_EXPIRY=7d

# Database (for backend)
DATABASE_URL=postgresql://user:password@localhost:5432/payment_gateway
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=Raj@76330Raj
DB_NAME=payment_gateway

# Payment Gateway Configuration (Our own - no Stripe/Razorpay)
# Direct bank/NPCI integration when licensed

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Admin Configuration
ADMIN_EMAIL=admin@paymentgateway.com
ADMIN_PASSWORD=change-this-password

# Feature Flags
ENABLE_3D_SECURE=true
ENABLE_UPI_PAYMENTS=true
ENABLE_INTERNATIONAL_PAYMENTS=false

# Logging
LOG_LEVEL=info
